<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JDM Supply - Premium Car Marketplace</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Segoe UI', sans-serif; }
        body { background-color: #0b0c10; color: #c5c6c7; line-height: 1.6; }
        a { color: #66fcf1; text-decoration: none; }
        header { background-color: #1f2833; padding: 20px 8%; display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #66fcf1; position: sticky; top: 0; z-index: 100; }
        .logo { font-size: 24px; font-weight: bold; color: #fff; letter-spacing: 2px; }
        .logo span { color: #66fcf1; }
        .dealer-badge { background-color: #0b0c10; padding: 5px 15px; border-radius: 20px; border: 1px solid #45f3ff; font-size: 0.85rem; }
        .hero-dashboard { background: linear-gradient(rgba(11, 12, 16, 0.95), rgba(11, 12, 16, 0.9)), url('https://images.unsplash.com/photo-1616422285623-13ff0162193c?auto=format&fit=crop&w=1200&q=80') center center/cover; padding: 50px 8% 30px 8%; border-bottom: 1px solid #1f2833; }
        .dashboard-grid { display: grid; grid-template-columns: 1.5fr 1.2fr; gap: 40px; align-items: start; }
        @media (max-width: 900px) { .dashboard-grid { grid-template-columns: 1fr; } }
        .dealer-profile h1 { color: #fff; font-size: 2.3rem; margin-bottom: 10px; }
        .dealer-meta { display: flex; gap: 20px; margin-bottom: 15px; flex-wrap: wrap; }
        .meta-item strong { color: #66fcf1; }
        .upload-panel { background-color: #11141a; border: 1px solid #66fcf1; border-radius: 8px; padding: 20px; }
        .upload-panel h3 { color: #fff; margin-bottom: 15px; font-size: 1.2rem; border-bottom: 1px solid #2e3944; padding-bottom: 8px; }
        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .form-group { display: flex; flex-direction: column; }
        .form-group.full-width { grid-column: span 2; }
        .form-group label { font-size: 0.8rem; color: #a8a9ad; margin-bottom: 4px; }
        .form-group input, .form-group select { background-color: #0b0c10; border: 1px solid #2e3944; color: #fff; padding: 8px 12px; border-radius: 4px; outline: none; font-size: 0.9rem; }
        .form-group input:focus, .form-group select:focus { border-color: #66fcf1; }
        .btn-submit { background-color: #66fcf1; color: #0b0c10; border: none; padding: 10px; border-radius: 4px; font-weight: bold; cursor: pointer; margin-top: 15px; transition: 0.2s; width: 100%; }
        .btn-submit:hover { background-color: #45f3ff; }
        .filter-bar { background-color: #1f2833; padding: 20px; border-radius: 8px; margin-top: 30px; display: flex; gap: 15px; align-items: center; flex-wrap: wrap; }
        .filter-bar input, .filter-bar select { background-color: #0b0c10; border: 1px solid #45f3ff; color: #fff; padding: 10px 15px; border-radius: 4px; outline: none; flex: 1; min-width: 200px; }
        .main-container { padding: 40px 8%; }
        .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; }
        .lot-count { color: #66fcf1; font-weight: bold; background: rgba(102, 252, 241, 0.1); padding: 4px 12px; border-radius: 12px; }
        .marketplace-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px; }
        .car-card { background-color: #1f2833; border-radius: 8px; overflow: hidden; border: 1px solid #2e3944; cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .car-card:hover { transform: translateY(-5px); box-shadow: 0 8px 20px rgba(102, 252, 241, 0.15); }
        .card-img-holder { position: relative; width: 100%; height: 180px; background-color: #111; }
        .card-img-holder img { width: 100%; height: 100%; object-fit: cover; }
        .badge-featured { position: absolute; top: 10px; left: 10px; padding: 3px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; text-transform: uppercase; background-color: #ff9f43; color: #fff; }
        .price-tag { position: absolute; bottom: 10px; left: 10px; background-color: rgba(11, 12, 16, 0.9); color: #66fcf1; font-weight: bold; font-size: 1.1rem; padding: 4px 10px; border-radius: 4px; border-left: 3px solid #66fcf1; }
        .card-body { padding: 15px; }
        .card-body h4 { color: #fff; font-size: 1.1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 5px; }
        .card-specs { display: flex; justify-content: space-between; font-size: 0.8rem; color: #a8a9ad; margin-bottom: 12px; border-bottom: 1px solid #2e3944; padding-bottom: 8px; }
        .location-box { display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; color: #2ecc71; }
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.85); backdrop-filter: blur(5px); display: none; justify-content: center; align-items: center; z-index: 1000; padding: 20px; }
        .modal-content { background-color: #1f2833; width: 100%; max-width: 800px; border-radius: 12px; border: 2px solid #66fcf1; overflow: hidden; position: relative; animation: modalFadeIn 0.3s ease; }
        @keyframes modalFadeIn { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .close-modal { position: absolute; top: 15px; right: 20px; font-size: 30px; color: #fff; cursor: pointer; z-index: 10; }
        .modal-grid { display: grid; grid-template-columns: 1fr 1fr; }
        @media (max-width: 768px) { .modal-grid { grid-template-columns: 1fr; } }
        .modal-img-wrap { height: 100%; min-height: 300px; background-color: #111; }
        .modal-img-wrap img { width: 100%; height: 100%; object-fit: cover; }
        .modal-details { padding: 30px; display: flex; flex-direction: column; justify-content: space-between; }
        .modal-details h2 { color: #fff; margin-bottom: 5px; }
        .modal-price { color: #66fcf1; font-size: 1.8rem; font-weight: bold; margin: 10px 0; }
        .specs-table { width: 100%; margin-bottom: 20px; font-size: 0.9rem; }
        .specs-table td { padding: 6px 0; border-bottom: 1px solid #2e3944; }
        .specs-table td:first-child { color: #a8a9ad; width: 40%; }
        .btn-action { background-color: #66fcf1; color: #0b0c10; border: none; padding: 12px; border-radius: 6px; font-weight: bold; cursor: pointer; text-align: center; width: 100%; transition: 0.2s; display: block; }
        .btn-action:hover { background-color: #45f3ff; }
        footer { background-color: #1f2833; text-align: center; padding: 30px; margin-top: 60px; border-top: 1px solid #2e3944; font-size: 0.9rem; }
    </style>
</head>
<body>
    <header>
        <div class="logo">JDM<span>SUPPLY</span></div>
        <div class="dealer-badge">Showroom Manager: <strong>Waqar Ahmed</strong></div>
    </header>
    <section class="hero-dashboard">
        <div class="dashboard-grid">
            <div class="dealer-profile">
                <h1>Waqar Ahmed • Marketplace Portfolio</h1>
                <div class="dealer-meta">
                    <div class="meta-item">Region Base: <strong>Virginia, USA</strong></div>
                    <div class="meta-item">Helpline Line: <a href="tel:+923172553419"><strong>+92 317 2553419</strong></a></div>
                    <div class="meta-item">Status: <span style="color:#2ecc71;">● Verified Direct Vendor</span></div>
                </div>
                <p style="margin-bottom: 15px;">Welcome to an open JDM collection portal inspired by traditional auto databases. Use the system submission panel on the right to append your stock listings directly into the visual network catalogue safely.</p>
            </div>
            <div class="upload-panel">
                <h3>➕ Add New Car to Showroom</h3>
                <form id="carUploadForm" onsubmit="handleFormSubmit(event)">
                    <div class="form-grid">
                        <div class="form-group"><label>Model Year</label><input type="number" id="formYear" placeholder="e.g. 1998" required min="1970" max="2027"></div>
                        <div class="form-group"><label>Make/Model Name</label><input type="text" id="formTitle" placeholder="e.g. Suzuki Carry" required></div>
                        <div class="form-group"><label>Price (USD)</label><input type="number" id="formPrice" placeholder="e.g. 5200" required></div>
                        <div class="form-group"><label>Mileage (km)</label><input type="number" id="formMileage" placeholder="e.g. 45000" required></div>
                        <div class="form-group"><label>Class Category</label><select id="formCategory"><option value="kei">Kei Mini Truck/Van</option><option value="sports">Sports Classic</option></select></div>
                        <div class="form-group"><label>Grade Level</label><input type="text" id="formGrade" placeholder="e.g. 4.0 / Clean" required></div>
                        <div class="form-group full-width"><label>Custom Image URL (Leave blank for auto stock photo)</label><input type="url" id="formImg" placeholder="https://images.unsplash.com/..."></div>
                    </div>
                    <button type="submit" class="btn-submit">Publish Live Listing</button>
                </form>
            </div>
        </div>
        <div class="filter-bar">
            <input type="text" id="searchBar" placeholder="Search stock inventory..." onkeyup="filterInventory()">
            <select id="categoryFilter" onchange="filterInventory()"><option value="all">All Category Classes</option><option value="kei">Kei Mini Trucks / Vans</option><option value="sports">Sports / Performance Classics</option></select>
        </div>
    </section>
    <main class="main-container">
        <div class="section-header">
            <h2>Current Storefront Vehicles</h2>
            <div class="lot-count">Active Registry: <span id="totalLotsDisplay">55</span> Units</div>
        </div>
        <div class="marketplace-grid" id="inventoryGrid"></div>
    </main>
    <div class="modal-overlay" id="carModal" onclick="closeModalOutside(event)"><div class="modal-content"><span class="close-modal" onclick="closeCarModal()">&times;</span><div class="modal-grid" id="modalDataBox"></div></div></div>
    <footer><p>&copy; 2026 JDM Supply Network | Powered by GitHub Pages Layout.</p></footer>
    <script>
        const itemNamesKei = ["Suzuki Carry 4WD", "Honda Acty SDX", "Daihatsu Hijet Climber", "Subaru Sambar High-Roof", "Mitsubishi Minicab"];
        const itemNamesSports = ["Nissan Skyline GT-R R34", "Toyota Supra MK4 2JZ", "Mazda RX-7 FD3S", "Nissan Silvia S15 Spec-R", "Honda NSX NA1"];
        const imageLibraryKei = ["https://images.unsplash.com/photo-1516515429572-bf32372f2409?auto=format&fit=crop&w=500&q=80","https://images.unsplash.com/photo-1552519507-da3b142c6e3d?auto=format&fit=crop&w=500&q=80","https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?auto=format&fit=crop&w=500&q=80","https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=500&q=80"];
        const imageLibrarySports = ["https://images.unsplash.com/photo-1617814076367-b759c7d7e738?auto=format&fit=crop&w=500&q=80","https://images.unsplash.com/photo-1616422285623-13ff0162193c?auto=format&fit=crop&w=500&q=80","https://images.unsplash.com/photo-1580273916550-e323be2ae537?auto=format&fit=crop&w=500&q=80","https://images.unsplash.com/photo-1605559424843-9e4c228bf1c2?auto=format&fit=crop&w=500&q=80"];
        let database = [];
        for(let i = 1; i <= 55; i++) {
            let isKei = i <= 40;
            let modelName = isKei ? itemNamesKei[i % itemNamesKei.length] : itemNamesSports[i % itemNamesSports.length];
            let baseImg = isKei ? imageLibraryKei[i % imageLibraryKei.length] : imageLibrarySports[i % imageLibrarySports.length];
            let imgUrl = `${baseImg}&sig=${i}`;
            let priceValue = isKei ? (3200 + (i * 75)) : (35000 + (i * 900));
            database.push({ id: Date.now() + i, stockNum: `STK-${4000 + i}`, title: `${1993 + (i % 12)} ${modelName}`, category: isKei ? "kei" : "sports", engine: isKei ? "660cc EFI 3-Cylinder" : "Twin-Cam Multi-Valve Sports Motor", transmission: isKei ? "5-Speed Manual MT" : "6-Speed Performance Short-Shifter", mileage: `${42000 + (i * 950)} km`, price: priceValue, grade: (i % 2 === 0) ? "4.5" : "4.0", chassis: `JDM-${200000 + i}`, img: imgUrl, location: "Available / Sourced" });
        }
        function displayCards(dataList) {
            const grid = document.getElementById("inventoryGrid"); grid.innerHTML = "";
            if(dataList.length === 0) { grid.innerHTML = `<div style="grid-column: 1/-1; text-align:center; padding:40px; color:#a8a9ad;">No items match search.</div>`; return; }
            const sortedList = [...dataList].reverse();
            sortedList.forEach(car => {
                const card = document.createElement("div"); card.className = "car-card"; card.setAttribute("onclick", `openCarModal(${car.id})`);
                card.innerHTML = `<div class="card-img-holder"><img src="${car.img}"><span class="badge-featured">Featured</span><div class="price-tag">$${car.price.toLocaleString()}</div></div><div class="card-body"><h4>${car.title}</h4><div class="card-specs"><span>${car.stockNum}</span><span>Grade: ${car.grade}</span><span>${car.mileage}</span></div><div class="location-box"><span>📍 Ready to Deliver</span><span style="font-weight: bold; color: #66fcf1;">View Details</span></div></div>`;
                grid.appendChild(card);
            });
            document.getElementById("totalLotsDisplay").innerText = dataList.length;
        }
        function handleFormSubmit(event) {
            event.preventDefault();
            const year = document.getElementById("formYear").value;
            const title = document.getElementById("formTitle").value;
            const price = parseInt(document.getElementById("formPrice").value);
            const mileage = parseInt(document.getElementById("formMileage").value);
            const category = document.getElementById("formCategory").value;
            const grade = document.getElementById("formGrade").value;
            let img = document.getElementById("formImg").value;
            if(!img) { let randomLibrary = category === "kei" ? imageLibraryKei : imageLibrarySports; img = randomLibrary[Math.floor(Math.random() * randomLibrary.length)] + `&sig=${Math.floor(Math.random() * 100)}`; }
            const newCarObj = { id: Date.now(), stockNum: `STK-${Math.floor(Math.random() * 9000) + 1000}`, title: `${year} ${title}`, category: category, engine: category === "kei" ? "660cc Eco-Engine" : "High Output Performance Engine", transmission: "Manual Transmission Asset", mileage: `${mileage.toLocaleString()} km`, price: price, grade: grade, chassis: `JDM-${Math.floor(Math.random() * 899999) + 100000}`, img: img, location: "User Uploaded Showcase" };
            database.push(newCarObj); displayCards(database); document.getElementById("carUploadForm").reset(); alert("Success! Your car was uploaded.");
        }
        function filterInventory() {
            const searchVal = document.getElementById("searchBar").value.toLowerCase();
            const catVal = document.getElementById("categoryFilter").value;
            const filtered = database.filter(car => { return (car.title.toLowerCase().includes(searchVal) || car.stockNum.toLowerCase().includes(searchVal)) && ((catVal === "all") || (car.category === catVal)); });
            displayCards(filtered);
        }
        function openCarModal(id) {
            const car = database.find(c => c.id === id); if(!car) return;
            document.getElementById("modalDataBox").innerHTML = `<div class="modal-img-wrap"><img src="${car.img}"></div><div class="modal-details"><div><span style="color:#66fcf1; font-weight:bold; font-size:0.9rem; text-transform:uppercase;">ID: ${car.stockNum} • Grade ${car.grade}</span><h2>${car.title}</h2><div class="modal-price">$${car.price.toLocaleString()}</div><table class="specs-table"><tr><td>Chassis Registry</td><td>${car.chassis}</td></tr><tr><td>Powertrain Motor</td><td>${car.engine}</td></tr><tr><td>Odometer Usage</td><td>${car.mileage}</td></tr><tr><td>Fulfillment</td><td>${car.location}</td></tr></table></div><div><a href="tel:+923172553419" class="btn-action">Contact Booking Agent to Buy</a></div></div>`;
            document.getElementById("carModal").style.display = "flex";
        }
        function closeCarModal() { document.getElementById("carModal").style.display = "none"; }
        function closeModalOutside(e) { if(e.target.id === "carModal") closeCarModal(); }
        displayCards(database);
    </script>
</body>
</html>
